{
  "rewrites": [
    {
      "source": "/docs",
      "destination": "https://orflow.mintlify.site/"
    },
    {
      "source": "/docs/:match*",
      "destination": "https://orflow.mintlify.site/:match*"
    },
    {
      "source": "/(api-reference|quickstart|core-concepts|guides|environment-setup)/:match*",
      "destination": "https://orflow.mintlify.site/$1/:match*"
    },
    {
      "source": "/(api-reference|quickstart|core-concepts|guides|environment-setup)",
      "destination": "https://orflow.mintlify.site/$1"
    },
    {
      "source": "/mintlify-assets/:match*",
      "destination": "https://orflow.mintlify.site/mintlify-assets/:match*"
    },
    {
      "source": "/_mintlify/:match*",
      "destination": "https://orflow.mintlify.site/_mintlify/:match*"
    },
    {
      "source": "/v1/:path*",
      "destination": "https://orflow-backend.onrender.com/v1/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "https://orflow-backend.onrender.com/v1/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
